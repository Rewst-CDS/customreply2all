<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" 
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
           xsi:type="MailApp">
  
  <Id>61b20d94-1560-4461-b31b-64190d7a6e98</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Internal IT Tools</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Special Reply"/>
  <Description DefaultValue="Triggers custom reply logic."/>
  
  <IconUrl DefaultValue="https://rewst-cds.github.io/customreply2all/icons/icon64.png"/>
  <HighResolutionIconUrl DefaultValue="https://rewst-cds.github.io/customreply2all/icons/icon80.png"/>
  <SupportUrl DefaultValue="https://rewst-cds.github.io/customreply2all/"/>
  
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.8"/>
    </Sets>
  </Requirements>
  
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://rewst-cds.github.io/customreply2all/commands.html"/>
        <RequestedHeight>32</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
</OfficeApp>