<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"  
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"  
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"  
  xsi:type="MailApp">

  <Id>61b20d94-1560-4461-b31b-64190d7a6e98</Id>
  <Version>1.0.0.5</Version> <ProviderName>Internal IT Tools</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Special Reply Tools"/>
  <Description DefaultValue="Custom reply mechanisms for complex mail threads."/>
  <IconUrl DefaultValue="https://rewst-cds.github.io/customreply2all/icons/icon64.png"/>
  <HighResolutionIconUrl DefaultValue="https://rewst-cds.github.io/customreply2all/icons/icon80.png"/>
  <SupportUrl DefaultValue="https://rewst-cds.github.io/customreply2all/"/>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.8"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://rewst-cds.github.io/customreply2all/commands.html"/>
        <RequestedHeight>32</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    
    <Requirements>
      <bt:Sets DefaultMinVersion="1.8">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Resources>
      <bt:Images>
        <bt:Image id="icon64" DefaultValue="https://rewst-cds.github.io/customreply2all/icons/icon64.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="residFunctionFile" DefaultValue="https://rewst-cds.github.io/customreply2all/commands.html"/>
        <bt:Url id="AutorunHtml" DefaultValue="https://rewst-cds.github.io/customreply2all/autorun.html"/>
        <bt:Url id="AutorunJs" DefaultValue="https://rewst-cds.github.io/customreply2all/autorun.js"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="residGroupName" DefaultValue="Custom Replying"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="residDescription" DefaultValue="Automates recipient shuffling to keep threads clean."/>
      </bt:LongStrings>
    </Resources>

    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      <Requirements>
        <bt:Sets DefaultMinVersion="1.10">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>
      
      <Hosts>
        <Host xsi:type="MailHost">
          <Runtimes>
            <Runtime resid="AutorunHtml">
              <Override type="javascript" resid="AutorunJs"/>
            </Runtime>
          </Runtimes>
          
          <DesktopFormFactor>
            <FunctionFile resid="AutorunHtml"/>
            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent Type="OnNewMessageCompose" FunctionName="onMessageComposeHandler"/>
              </LaunchEvents>
              <SourceLocation resid="AutorunHtml"/>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>
    </VersionOverrides>
    
  </VersionOverrides>

</OfficeApp>